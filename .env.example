# Copy this to .env and fill in your API key(s)

# Cerebras (fastest inference — recommended for testing)
CEREBRAS_API_KEY=your-cerebras-api-key-here

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Groq (fast inference)
GROQ_API_KEY=your-groq-api-key-here

# Model selection (litellm format):
# OI_MODEL=cerebras/gpt-oss-120b            (default — fastest)
# OI_MODEL=groq/llama-3.3-70b-versatile    (Groq)
# OI_MODEL=deepseek/deepseek-chat           (DeepSeek)
# OI_MODEL=openai/gpt-4o-mini               (OpenAI)
